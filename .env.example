DEBUG=True
SECRET_KEY=dev-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Localization & i18n
LANGUAGE_CODE=zh-hans
TIME_ZONE=Asia/Shanghai
USE_I18N=True
USE_TZ=True

# Database: configure using DSN format
# SQLite (default): sqlite:///db.sqlite3
# PostgreSQL: postgres://user:password@localhost:5432/dbname
# MySQL: mysql://user:password@localhost:3306/dbname
DATABASE_URL=sqlite:///db.sqlite3

# JWT API Authentication
# Leave JWT_SECRET_KEY empty to reuse SECRET_KEY
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=86400

# Email Configuration
# For production: Set both MAILGUN_API_KEY and MAILGUN_SENDER_DOMAIN to use Mailgun
# For local development: Leave empty to print emails to console
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_SENDER_DOMAIN=your-domain.com
MAILGUN_API_KEY=
MAILGUN_SENDER_DOMAIN=

# Optional AWS S3 media storage (requires all values)
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_LOCATION=
AWS_S3_REGION_NAME=
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ENDPOINT_URL=

# Social auth (scopes accept comma-separated lists)
# GitHub OAuth: https://github.com/settings/developers
SOCIAL_AUTH_GITHUB_KEY=
SOCIAL_AUTH_GITHUB_SECRET=
SOCIAL_AUTH_GITHUB_SCOPE=read:user,user:email

# Google OAuth
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
SOCIAL_AUTH_GOOGLE_OAUTH2_SCOPE=openid,email,profile

# GitLab OAuth
SOCIAL_AUTH_GITLAB_KEY=
SOCIAL_AUTH_GITLAB_SECRET=
SOCIAL_AUTH_GITLAB_SCOPE=read_user

# Bitbucket OAuth
SOCIAL_AUTH_BITBUCKET_OAUTH2_KEY=
SOCIAL_AUTH_BITBUCKET_OAUTH2_SECRET=
SOCIAL_AUTH_BITBUCKET_OAUTH2_SCOPE=account,email

# Docker Hub OAuth
SOCIAL_AUTH_DOCKER_KEY=
SOCIAL_AUTH_DOCKER_SECRET=
SOCIAL_AUTH_DOCKER_SCOPE=read

# Facebook OAuth
SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=
SOCIAL_AUTH_FACEBOOK_SCOPE=email,public_profile

# LinkedIn OAuth
SOCIAL_AUTH_LINKEDIN_OAUTH2_KEY=
SOCIAL_AUTH_LINKEDIN_OAUTH2_SECRET=
SOCIAL_AUTH_LINKEDIN_OAUTH2_SCOPE=r_liteprofile,r_emailaddress

# Twitter OAuth
SOCIAL_AUTH_TWITTER_OAUTH2_KEY=
SOCIAL_AUTH_TWITTER_OAUTH2_SECRET=

# Gitea OAuth (自托管)
SOCIAL_AUTH_GITEA_KEY=
SOCIAL_AUTH_GITEA_SECRET=
SOCIAL_AUTH_GITEA_API_URL=
SOCIAL_AUTH_GITEA_SCOPE=read:user,user:email

# Gitee OAuth: https://gitee.com/oauth/applications
SOCIAL_AUTH_GITEE_KEY=
SOCIAL_AUTH_GITEE_SECRET=
SOCIAL_AUTH_GITEE_SCOPE=user_info,emails

# AtomGit OAuth: https://atomgit.com/-/profile/applications
SOCIAL_AUTH_ATOMGIT_KEY=
SOCIAL_AUTH_ATOMGIT_SECRET=
SOCIAL_AUTH_ATOMGIT_SCOPE=user

# HuggingFace OAuth: https://huggingface.co/settings/applications/new
SOCIAL_AUTH_HUGGINGFACE_KEY=
SOCIAL_AUTH_HUGGINGFACE_SECRET=
SOCIAL_AUTH_HUGGINGFACE_SCOPE=openid,profile,email

# Redis 缓存配置（可选，生产环境推荐）
REDIS_URL=

# IP 归属地查询（ip2region xdb 离线库）
# 用于登录页根据访问者 IP 是否为中国大陆决定是否展示 AtomGit 入口。
#
# Docker 部署：镜像构建时已通过 Dockerfile 自动下载 xdb 文件并通过 ENV 配置好路径
#   （/app/data/ip2region_v4.xdb），无需在此处填写。
# 本地开发：可从 https://github.com/lionsoul2014/ip2region 仓库 data/ip2region.xdb 下载，
#   保存到任意位置后将该路径填入下方变量。
# 留空或文件不存在时，接口会返回 is_mainland_cn=null，前端按默认（仅 GitHub）展示。
IP2REGION_XDB_PATH=

# ClickHouse Configuration
# For local development: defaults to localhost with default user
# For production: configure with your ClickHouse server details
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_SECURE=False

# Misc (optional overrides)
# DEFAULT_AUTO_FIELD=django.db.models.BigAutoField

# 身边云 Configuration
# DES 密钥
SBY_INTER_KEY=
#商户私钥
SBY_MER_PRIVATE_KEY=
#商户公钥
SBY_MER_PUBLIC_KEY=
#平台公钥
SBY_FU_PUBLIC_KEY=
SBY_MER_ID=
# 任务ID
SBY_TASK_ID=
# API版本号
SBY_API_VERSION=V1.0
# 服务商ID
SBY_PROVIDER_ID=
# API URL
SBY_FU_URL=
